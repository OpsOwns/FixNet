{
  "Logging": {
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "ColorBehavior": "Enabled",
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "API.Utilities": "Debug"
    }
  }
}